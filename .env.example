# Padel Tournament Manager - Environment Configuration Template
# Copy this file to .env and customize the values

# ============================================================================
# JWT Authentication Secret
# ============================================================================
# Used to sign JWT tokens for user authentication
# IMPORTANT: Use a strong random secret in production
# If not set, a random secret will be auto-generated and saved to data/.jwt_secret

# PADEL_JWT_SECRET=your-super-secret-key-here-change-this-in-production

# ============================================================================
# Server Configuration (optional)
# ============================================================================
# These are typically set when deploying, not needed for local development

# HOST=0.0.0.0
# PORT=8000

# ============================================================================
# Data Directory (optional)
# ============================================================================
# Location where tournament data and state files are stored
# Default: ./data/

# DATA_DIR=/path/to/custom/data/directory

# ============================================================================
# Demo Mode (optional)
# ============================================================================
# Show a warning banner on the frontend indicating this is a demo instance
# where data may be lost. Useful for free-tier cloud deployments.
# Default: false

# DEMO_MODE=true

# ============================================================================
# SMTP / Email (optional)
# ============================================================================
# Leave as None to keep email functionality disabled.
# To enable, set real SMTP values (e.g. Gmail SMTP).

# AMISTOSO_SMTP_HOST=None
# AMISTOSO_SMTP_PORT=None
# AMISTOSO_SMTP_USER=None
# AMISTOSO_SMTP_PASS=None
# AMISTOSO_FROM_EMAIL=None
# AMISTOSO_SMTP_USE_TLS=None
# AMISTOSO_SITE_URL=None

# ============================================================================
# Docker Compose — Host Port
# ============================================================================
# The host port the app will be accessible on when running via Docker Compose.
# The container always listens on 8000 internally.
# Default: 8000

# HOST_PORT=8000